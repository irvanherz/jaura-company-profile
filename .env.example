# Bunny Storage (required)
BUNNY_STORAGE_ZONE=your-storage-zone-name
BUNNY_STORAGE_ACCESS_KEY=your-storage-zone-password

# Optional: primary storage region (e.g. sg, ny, uk, de, syd)
# BUNNY_STORAGE_REGION=

# Optional: upload into a subfolder inside the storage zone
# BUNNY_STORAGE_PATH=

# Optional: parallel uploads (default: 8)
# BUNNY_UPLOAD_CONCURRENCY=8

# Optional: purge Bunny CDN pull zone after deploy
# BUNNY_PULL_ZONE_ID=
# BUNNY_API_KEY=
